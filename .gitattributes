# Auto detect text files and perform LF normalization
* text=auto

# Java — always LF
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.gradle text eol=lf

# Python — always LF
*.py text eol=lf
*.pyc binary

# Web — always LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf

# Config & scripts
*.sh text eol=lf
*.conf text eol=lf
*.md text eol=lf
*.sql text eol=lf
Dockerfile text eol=lf
Dockerfile.* text eol=lf

# Windows scripts — keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binary files
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.ico binary
*.zip binary
*.tar.gz binary
